{
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/identity/{**catch-all}"
        }
      },
      "roles-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/roles/{**catch-all}"
        }
      },
      "accounts-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/accounts/{**catch-all}"
        }
      },
      "auth-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "shop-route": {
        "ClusterId": "shop-cluster",
        "Match": {
          "Path": "/api/shop/{**catch-all}"
        }
      },
      "product-route": {
        "ClusterId": "product-cluster",
        "Match": {
          "Path": "/api/product/{**catch-all}"
        }
      },
      "inventory-route": {
        "ClusterId": "inventory-cluster",
        "Match": {
          "Path": "/api/inventory/{**catch-all}"
        }
      },
      "order-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        }
      },
      "order-admin-dashboard-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/api/admin/dashboard/{**catch-all}"
        }
      },
      "order-dashboard-hub-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/admin-dashboard-hub/{**catch-all}"
        }
      },
      "order-realtime-hub-route": {
        "ClusterId": "order-cluster",
        "Match": {
          "Path": "/hubs/orders/{**catch-all}"
        }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": {
          "Path": "/api/payment/{**catch-all}"
        }
      },
        "wallets-route": {
          "ClusterId": "payment-cluster",
          "Match": {
            "Path": "/api/wallets/{**catch-all}"
          }
        },
      "shipment-route": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/api/shipment/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-destination": {
            "Address": "http://replace-via-env-identity"
          }
        }
      },
      "shop-cluster": {
        "Destinations": {
          "shop-destination": {
            "Address": "http://replace-via-env-shop"
          }
        }
      },
      "product-cluster": {
        "Destinations": {
          "product-destination": {
            "Address": "http://replace-via-env-product"
          }
        }
      },
      "inventory-cluster": {
        "Destinations": {
          "inventory-destination": {
            "Address": "http://replace-via-env-inventory"
          }
        }
      },
      "order-cluster": {
        "Destinations": {
          "order-destination": {
            "Address": "http://replace-via-env-order"
          }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment-destination": {
            "Address": "http://replace-via-env-payment"
          }
        }
      },
      "shipment-cluster": {
        "Destinations": {
          "shipment-destination": {
            "Address": "http://replace-via-env-shipment"
          }
        }
      }
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "System": "Warning",
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.AspNetCore.Routing.EndpointMiddleware": "Information",
        "Microsoft.AspNetCore.Hosting.Diagnostics": "Information",
        "Yarp": "Information"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Yarp": "Information"
    }
  }
}
